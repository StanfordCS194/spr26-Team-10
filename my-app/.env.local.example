# Copy this file to `.env.local` and fill in your secrets.
# `.env.local` is gitignored.

# OpenAI API key — used by the streaming chat at /chat (app/api/chat/route.ts).
OPENAI_API_KEY=

# Supabase — public values (safe to expose to the browser).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — service role (server only). Required for API routes to insert/update
# when Row Level Security blocks the anon key. Get it from Supabase Dashboard →
# Project Settings → API → service_role (secret). Do NOT use NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=
